# Cloudflare Pages _redirects only supports plain redirects (source/destination/status).
# Locale detection for `/` (cookie -> Accept-Language -> CF-IPCountry -> en) is
# handled at the edge by /functions/index.ts. There must be no static /index.html,
# or it would shadow the function and the geo redirect would never run.

/sitemap.xml  /sitemap-index.xml  200

# Feature flags API: keep the URL extensionless while serving a static JSON file.
# Two lines so both /api/feature_flags and /api/feature_flags/ work.
/api/feature_flags   /api/feature_flags.json  200
/api/feature_flags/  /api/feature_flags.json  200
