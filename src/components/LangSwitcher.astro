---
import {
  LOCALES,
  getDict,
  localizedPath,
  stripLocale,
  type Locale,
} from '../i18n';

interface Props {
  current: Locale;
  path: string;
}

const { current, path } = Astro.props;
const baseRoute = stripLocale(path);
const t = getDict(current);

const shortLabels: Record<Locale, string> = {
  en: 'EN',
  ru: 'RU',
};

const fullLabels: Record<Locale, string> = {
  en: t.langSwitcher.en,
  ru: t.langSwitcher.ru,
};
---

<div
  class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--surface)] p-1 text-xs font-semibold"
  role="group"
  aria-label={t.langSwitcher.label}
>
  {
    LOCALES.map((loc) => {
      const isActive = loc === current;
      return (
        <a
          href={localizedPath(loc, baseRoute)}
          hreflang={loc}
          data-lang={loc}
          data-lang-toggle
          aria-current={isActive ? 'true' : undefined}
          aria-label={`${t.langSwitcher.label}: ${fullLabels[loc]}`}
          class:list={[
            'rounded-full px-3 py-1 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand)]',
            isActive
              ? 'bg-[var(--brand)] text-white shadow-sm pointer-events-none'
              : 'text-[var(--muted)] hover:text-[var(--fg)]',
          ]}
        >
          {shortLabels[loc]}
        </a>
      );
    })
  }
</div>

<script is:inline>
  document.addEventListener('click', function (e) {
    var target = e.target;
    if (!(target instanceof Element)) return;
    var link = target.closest('a[data-lang-toggle]');
    if (!link) return;
    var lang = link.getAttribute('data-lang');
    if (!lang) return;
    try {
      document.cookie = 'zb_locale=' + lang + '; path=/; max-age=31536000; samesite=lax';
    } catch (_) { /* no-op */ }
  });
</script>
