---
import {
  getDict,
  localizedPath,
  stripLocale,
  type Locale,
} from '../i18n';
import {
  LOCALES,
  LOCALE_NATIVE_LABELS,
  LOCALE_SHORT_LABELS,
} from '../lib/siteConfig';

interface Props {
  current: Locale;
  path: string;
}

const { current, path } = Astro.props;
const baseRoute = stripLocale(path);
const t = getDict(current);
---

<div class="relative" data-lang-switcher>
  <button
    type="button"
    class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] bg-[var(--surface)] px-3 py-1.5 text-xs font-semibold text-[var(--fg)] transition-colors hover:border-[var(--brand)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand)]"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label={t.langSwitcher.label}
    data-lang-switcher-toggle
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.5-2.5 4-6 4-9s-1.5-6.5-4-9m0 18C9.5 18.5 8 15 8 12s1.5-6.5 4-9M3.5 9h17M3.5 15h17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span data-lang-switcher-current>{LOCALE_SHORT_LABELS[current]}</span>
    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <ul
    role="listbox"
    aria-label={t.langSwitcher.label}
    class="invisible absolute right-0 z-50 mt-2 max-h-[60vh] w-44 overflow-y-auto rounded-xl border border-[var(--border)] bg-[var(--surface)] py-1 text-sm opacity-0 shadow-xl transition-opacity duration-150"
    data-lang-switcher-menu
  >
    {
      LOCALES.map((loc) => {
        const isActive = loc === current;
        return (
          <li>
            <a
              href={localizedPath(loc, baseRoute)}
              hreflang={loc}
              data-lang={loc}
              data-lang-toggle
              role="option"
              aria-selected={isActive ? 'true' : 'false'}
              class:list={[
                'flex items-center justify-between gap-3 px-3 py-2 transition-colors focus:outline-none',
                isActive
                  ? 'bg-[var(--brand)]/10 text-[var(--brand-strong)] font-semibold'
                  : 'text-[var(--fg)] hover:bg-[var(--bg-elevated)] hover:text-[var(--fg)]',
              ]}
            >
              <span>{LOCALE_NATIVE_LABELS[loc]}</span>
              <span class="text-xs text-[var(--muted)] uppercase">{LOCALE_SHORT_LABELS[loc]}</span>
            </a>
          </li>
        );
      })
    }
  </ul>
</div>

<script is:inline>
  (function () {
    function init() {
      document.querySelectorAll('[data-lang-switcher]').forEach(function (root) {
        if (root.dataset.langInit === '1') return;
        root.dataset.langInit = '1';
        var toggle = root.querySelector('[data-lang-switcher-toggle]');
        var menu = root.querySelector('[data-lang-switcher-menu]');
        if (!toggle || !menu) return;
        function open() {
          menu.classList.remove('invisible', 'opacity-0');
          menu.classList.add('opacity-100');
          toggle.setAttribute('aria-expanded', 'true');
        }
        function close() {
          menu.classList.add('invisible', 'opacity-0');
          menu.classList.remove('opacity-100');
          toggle.setAttribute('aria-expanded', 'false');
        }
        toggle.addEventListener('click', function (e) {
          e.stopPropagation();
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          if (expanded) close(); else open();
        });
        document.addEventListener('click', function (e) {
          if (!root.contains(e.target)) close();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') close();
        });
      });
    }
    init();
    document.addEventListener('astro:page-load', init);

    document.addEventListener('click', function (e) {
      var target = e.target;
      if (!(target instanceof Element)) return;
      var link = target.closest('a[data-lang-toggle]');
      if (!link) return;
      var lang = link.getAttribute('data-lang');
      if (!lang) return;
      try {
        document.cookie = 'zb_locale=' + lang + '; path=/; max-age=31536000; samesite=lax';
      } catch (_) { /* no-op */ }
    });
  })();
</script>
