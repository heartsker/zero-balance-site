---
import Container from './Container.astro';
import Section from './Section.astro';
import Reveal from './Reveal.astro';
import { getDict, type Locale } from '../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getDict(lang);
---

<Section id="reviews">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <Reveal>
        <h2 class="h2 text-balance">{t.reviews.title}</h2>
      </Reveal>
      <Reveal delay={80}>
        <p class="lead mt-4 text-pretty">{t.reviews.subtitle}</p>
      </Reveal>
    </div>

    <div class="mx-auto mt-10 grid max-w-5xl gap-6 md:mt-14 md:grid-cols-3">
      {
        t.reviews.items.map((review, i) => (
          <Reveal delay={i * 60}>
            <figure class="flex h-full flex-col rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 shadow-sm">
              <div class="flex items-center gap-0.5 text-[var(--brand)]" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 1.6l2.6 5.3 5.8.8-4.2 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8L1.6 7.7l5.8-.8L10 1.6z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-4 flex-1 text-pretty text-[var(--fg)] leading-relaxed">
                &ldquo;{review.body}&rdquo;
              </blockquote>
              <figcaption class="mt-4 text-sm text-[var(--muted)]">
                - {review.author}, App Store
              </figcaption>
            </figure>
          </Reveal>
        ))
      }
    </div>
  </Container>
</Section>
