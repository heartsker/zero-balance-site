---
interface Props {
  delay?: number;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { delay = 0, as: Tag = 'div', class: className = '' }: Props = Astro.props;
const style = delay ? `transition-delay: ${delay}ms;` : undefined;
---

<Tag class:list={['reveal', className]} style={style}>
  <slot />
</Tag>
