---
import Container from './Container.astro';
import { getDict, type Locale } from '../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getDict(lang);
---

<div class="border-y border-[var(--border)] bg-[var(--surface)]">
  <Container class="py-6">
    <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-medium text-[var(--muted)]">
      {
        t.trust.items.map((label) => (
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path
                d="M10 1l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 14.8 4.7 17.1l1-5.8L1.5 7.2l5.9-.9L10 1z"
                stroke="var(--brand)"
                stroke-width="1.6"
                stroke-linejoin="round"
              />
            </svg>
            <span>{label}</span>
          </li>
        ))
      }
    </ul>
  </Container>
</div>
