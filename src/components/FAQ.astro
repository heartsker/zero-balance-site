---
interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-[var(--border)] overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--surface)]">
  {
    items.map((item, i) => (
      <details class="group" open={i === 0}>
        <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-5 py-5 text-left font-medium text-[var(--fg)] transition-colors hover:bg-[var(--brand-soft)]/40 md:px-6 md:py-6">
          <span>{item.q}</span>
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
            class="mt-0.5 shrink-0 transition-transform duration-200 group-open:rotate-45"
          >
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
          </svg>
        </summary>
        <div class="px-5 pb-6 text-[var(--muted)] md:px-6">
          <p>{item.a}</p>
        </div>
      </details>
    ))
  }
</div>
