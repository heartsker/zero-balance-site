---
import { DOMAIN, LOCALES } from '../lib/siteConfig';
import { localizedPath, stripLocale, type Locale } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  path: string;
  image?: string;
  noindex?: boolean;
  keywords?: string[];
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  lang,
  path,
  image = '/og-image.png',
  noindex = false,
  keywords,
  ogType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const normalizedPath = path.startsWith('/') ? path : `/${path}`;
const canonicalUrl = `${DOMAIN}${normalizedPath}`;
const ogImageUrl = image.startsWith('http') ? image : `${DOMAIN}${image}`;
const localePath = stripLocale(normalizedPath);
const altLocale: Locale = lang === 'ru' ? 'en' : 'ru';
const ogImageAlt =
  lang === 'ru'
    ? 'Zero Balance - приложение для iOS, помогает потратить остаток баланса Apple Account'
    : 'Zero Balance - iOS app that helps you spend leftover Apple Account balance';

const keywordsString = keywords?.length
  ? [...new Set(keywords.map((k) => k.trim()).filter(Boolean))].join(', ')
  : undefined;
---

<title>{title}</title>
<meta name="description" content={description} />
{keywordsString && <meta name="keywords" content={keywordsString} />}
<link rel="canonical" href={canonicalUrl} />
{noindex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}

<meta name="application-name" content="Zero Balance" />
<meta name="apple-mobile-web-app-title" content="Zero Balance" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="format-detection" content="telephone=no" />
<meta name="author" content="Daniel Pustotin" />
<meta name="generator" content="Astro" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="theme-color" content="#C32DAC" />
<meta http-equiv="content-language" content={lang} />

{
  LOCALES.map((l) => (
    <link rel="alternate" hreflang={l} href={`${DOMAIN}${localizedPath(l, localePath)}`} />
  ))
}
<link rel="alternate" hreflang="x-default" href={`${DOMAIN}${localizedPath('en', localePath)}`} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Zero Balance" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />
<meta property="og:locale:alternate" content={altLocale === 'ru' ? 'ru_RU' : 'en_US'} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />
