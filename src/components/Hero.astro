---
import AppStoreButton from './AppStoreButton.astro';
import Container from './Container.astro';
import RatingBadge from './RatingBadge.astro';
import { getDict, type Locale } from '../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getDict(lang);

const screenshots = [1, 2, 3, 4].map((n) => ({
  n,
  src: `/screenshots/${lang}/${n}.png`,
  alt:
    n === 1
      ? t.hero.screenshotAlt
      : n === 2
        ? t.hero.screenshotAlt2
        : `${t.meta.siteName} - iPhone`,
  eager: n === 1,
}));
---

<section class="relative overflow-hidden bg-aurora pt-12 pb-16 md:pt-24 md:pb-28">
  <Container>
    <div class="grid items-center gap-12 md:grid-cols-12 md:gap-10">
      <div class="md:col-span-6">
        <p class="hero-rise hero-rise-1 inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--surface)]/70 px-3 py-1 text-xs font-medium tracking-wide text-[var(--muted)] backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--brand)]" />
          {t.hero.eyebrow}
        </p>
        <h1 class="hero-rise hero-rise-2 mt-5 h1 text-balance">
          {t.hero.title}
        </h1>
        <p class="hero-rise hero-rise-3 mt-5 lead max-w-xl text-pretty">
          {t.hero.subtitle}
        </p>

        <ul class="hero-rise hero-rise-3 mt-6 flex flex-wrap gap-x-5 gap-y-2 text-sm text-[var(--muted)]">
          {
            t.hero.bullets.map((b) => (
              <li class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M4 10l4 4 8-9" stroke="var(--brand)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {b}
              </li>
            ))
          }
        </ul>

        <div class="hero-rise hero-rise-4 mt-5">
          <RatingBadge {lang} />
        </div>

        <div class="hero-rise hero-rise-4 mt-6 flex flex-wrap items-center gap-3">
          <AppStoreButton label={t.cta.appStore} size="lg" />
          <a
            href="#how-it-works"
            class="text-sm font-medium text-[var(--muted)] transition-colors hover:text-[var(--fg)]"
          >
            {t.cta.learnMore} &rarr;
          </a>
        </div>
      </div>

      <div class="md:col-span-6">
        <div class="relative w-full">
          <div
            class="absolute -inset-8 -z-10 rounded-full bg-[radial-gradient(closest-side,rgba(122,77,230,0.22),transparent)] blur-2xl"
            aria-hidden="true"
          />
          <div
            class="hero-rail hero-rise hero-rise-3"
            role="region"
            aria-label={t.hero.screenshotAlt}
            tabindex="0"
          >
            {
              screenshots.map((s) => (
                <div class="hero-rail-item">
                  <div class="hero-screen-frame">
                    <img
                      src={s.src}
                      alt={s.alt}
                      width="430"
                      height="932"
                      loading={s.eager ? 'eager' : 'lazy'}
                      fetchpriority={s.eager ? 'high' : 'low'}
                      decoding="async"
                      class="hero-screen-img"
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  function markLoaded(img: HTMLImageElement) {
    img.classList.add('is-loaded');
    img.parentElement?.classList.add('is-loaded');
  }
  function setupHeroPreviews() {
    document.querySelectorAll<HTMLImageElement>('.hero-screen-img').forEach((img) => {
      if (img.classList.contains('is-loaded')) return;
      if (img.complete && img.naturalWidth > 0) {
        markLoaded(img);
      } else {
        img.addEventListener('load', () => markLoaded(img), { once: true });
        img.addEventListener('error', () => markLoaded(img), { once: true });
      }
    });
  }
  setupHeroPreviews();
  document.addEventListener('astro:page-load', setupHeroPreviews);
</script>
