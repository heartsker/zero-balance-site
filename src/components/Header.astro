---
import { getDict, localizedPath, type Locale } from '../i18n';
import LangSwitcher from './LangSwitcher.astro';
import AppStoreButton from './AppStoreButton.astro';

interface Props {
  lang: Locale;
  path: string;
}

const { lang, path } = Astro.props;
const t = getDict(lang);

const navLinks = [
  { label: t.nav.home, href: localizedPath(lang, '') },
  { label: t.nav.faq, href: localizedPath(lang, 'faq') },
  { label: t.nav.help, href: localizedPath(lang, 'help') },
];
---

<header
  data-site-header
  class="sticky top-0 z-40 w-full border-b border-transparent transition-[background-color,border-color] duration-200"
>
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-5 py-3 md:px-8 md:py-4">
    <a
      href={localizedPath(lang, '')}
      class="inline-flex items-center gap-2 font-semibold tracking-tight"
      aria-label="Zero Balance home"
    >
      <picture>
        <source srcset="/icon-dark.png" media="(prefers-color-scheme: dark)" />
        <img
          src="/icon.png"
          alt=""
          width="32"
          height="32"
          class="h-8 w-8 rounded-lg shadow-sm"
          loading="eager"
          decoding="async"
        />
      </picture>
      <span class="text-base md:text-lg">Zero Balance</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-[var(--muted)] transition-colors hover:text-[var(--fg)]"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <LangSwitcher current={lang} path={path} />
      <div class="hidden sm:block">
        <AppStoreButton label={t.cta.appStoreShort} />
      </div>
    </div>
  </div>
</header>
