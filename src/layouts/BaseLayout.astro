---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import type { Locale } from '../i18n';
import { organizationSchema, websiteSchema } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  path: string;
  image?: string;
  noindex?: boolean;
  keywords?: string[];
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  lang,
  path,
  image,
  noindex,
  keywords,
  ogType,
  publishedTime,
  modifiedTime,
  schema,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <SEO {title} {description} {lang} {path} {image} {noindex} {keywords} {ogType} {publishedTime} {modifiedTime} />
    <JsonLd data={organizationSchema()} />
    <JsonLd data={websiteSchema({ lang })} />
    {schema && <JsonLd data={schema} />}
    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/reveal.ts';
    </script>
    <script is:inline>
      (function () {
        function applyHeader() {
          var header = document.querySelector('[data-site-header]');
          if (!header) return;
          var update = function () {
            if (window.scrollY > 8) header.classList.add('header-scrolled');
            else header.classList.remove('header-scrolled');
          };
          update();
          window.addEventListener('scroll', update, { passive: true });
        }
        applyHeader();
        document.addEventListener('astro:page-load', applyHeader);
      })();
    </script>
  </body>
</html>
