---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCta from '../components/StickyMobileCta.astro';
import QrFloater from '../components/QrFloater.astro';
import type { Locale } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  path: string;
  image?: string;
  noindex?: boolean;
  keywords?: string[];
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  locales?: Locale[];
}

const {
  title,
  description,
  lang,
  path,
  image,
  noindex,
  keywords,
  ogType,
  publishedTime,
  modifiedTime,
  schema,
  locales,
} = Astro.props;
---

<BaseLayout
  {title}
  {description}
  {lang}
  {path}
  {image}
  {noindex}
  {keywords}
  {ogType}
  {publishedTime}
  {modifiedTime}
  {schema}
  {locales}
>
  <Header {lang} {path} {locales} />
  <main id="main">
    <slot />
  </main>
  <Footer {lang} {path} {locales} />
  <StickyMobileCta {lang} />
  <QrFloater {lang} />
</BaseLayout>
