---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  path: string;
  image?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, lang, path, image, noindex, schema } = Astro.props;
---

<BaseLayout {title} {description} {lang} {path} {image} {noindex} {schema}>
  <Header {lang} {path} />
  <main id="main">
    <slot />
  </main>
  <Footer {lang} {path} />
</BaseLayout>
