---
import { DOMAIN, LOCALES } from '../lib/siteConfig';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Zero Balance - Spend leftover Apple Account balance</title>
    <meta
      name="description"
      content="Got leftover Apple Account balance or store credit you cannot shake? Zero Balance picks the closest pack of small App Store items to clear it."
    />
    <link rel="canonical" href={`${DOMAIN}/en/`} />
    {LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc} href={`${DOMAIN}/${loc}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${DOMAIN}/en/`} />
    <meta http-equiv="refresh" content="0; url=/en/" />
    <script is:inline define:vars={{ locales: [...LOCALES] }}>
      (function () {
        try {
          var path = location.pathname;
          if (path !== '/' && path !== '/index.html') return;
          var cookie = (document.cookie.match(/(?:^|; )zb_locale=([A-Za-z-]+)/) || [])[1];
          var lang = cookie && locales.indexOf(cookie) !== -1 ? cookie : '';
          if (!lang) {
            var navList = navigator.languages && navigator.languages.length ? navigator.languages : [navigator.language || 'en'];
            for (var i = 0; i < navList.length; i++) {
              var tag = String(navList[i]).toLowerCase();
              if (tag.indexOf('pt-br') === 0) { lang = 'pt-BR'; break; }
              if (tag.indexOf('pt') === 0) { lang = 'pt-BR'; break; }
              var primary = tag.split('-')[0];
              for (var j = 0; j < locales.length; j++) {
                var loc = locales[j].toLowerCase();
                if (loc === primary || loc.split('-')[0] === primary) { lang = locales[j]; break; }
              }
              if (lang) break;
            }
            if (!lang) lang = 'en';
          }
          location.replace('/' + lang + '/');
        } catch (_) {
          location.replace('/en/');
        }
      })();
    </script>
  </head>
  <body>
    <p style="font-family: system-ui, sans-serif; padding: 2rem;">
      Redirecting to <a href="/en/">/en/</a>...
    </p>
  </body>
</html>
