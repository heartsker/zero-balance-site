---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
---

<BaseLayout
  title="Not found - Zero Balance"
  description="The page you are looking for does not exist."
  lang="en"
  path="/404/"
  noindex={true}
>
  <Container class="flex min-h-[70vh] flex-col items-center justify-center py-20 text-center">
    <p class="text-6xl font-bold tracking-tight">404</p>
    <h1 class="mt-4 h2">Page not found</h1>
    <p class="mt-3 lead max-w-md">
      The page you are looking for does not exist or has moved.
    </p>
    <a href="/en/" class="cta mt-8">Go to homepage</a>
  </Container>
</BaseLayout>
