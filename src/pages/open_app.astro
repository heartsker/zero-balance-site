---
import '../styles/globals.css';
import { APP_ID, APP_NAME, ACCENT, DOMAIN } from '../lib/siteConfig';

const APP_STORE_URL = `https://apps.apple.com/app/apple-store/id${APP_ID}?pt=128302223&ct=in-app-event&mt=8`;
const REDIRECT_DELAY_MS = 1400;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Opening {APP_NAME}...</title>
    <meta name="description" content={`Opening ${APP_NAME} in the App Store.`} />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content={ACCENT} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-dark.ico" sizes="any" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-dark-192.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-itunes-app" content={`app-id=${APP_ID}, app-argument=${DOMAIN}/open_app/`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta http-equiv="refresh" content={`${Math.round(REDIRECT_DELAY_MS / 1000)}; url=${APP_STORE_URL}`} />
    <script is:inline define:vars={{ APP_STORE_URL, REDIRECT_DELAY_MS }}>
      window.setTimeout(function () {
        location.replace(APP_STORE_URL);
      }, REDIRECT_DELAY_MS);
    </script>
  </head>
  <body class="bg-aurora">
    <main class="relative min-h-[100dvh] grid place-items-center px-6 py-12">
      <div class="text-center max-w-md">
        <picture>
          <source srcset="/icon-dark.png" media="(prefers-color-scheme: dark)" />
          <img
            src="/icon.png"
            alt={`${APP_NAME} app icon`}
            width="96"
            height="96"
            class="hero-rise hero-rise-1 mx-auto h-24 w-24 rounded-[1.25rem] shadow-[0_20px_50px_-15px_rgba(122,77,230,0.55)] ring-1 ring-black/5"
          />
        </picture>

        <h1 class="hero-rise hero-rise-2 mt-7 h2 text-balance">
          Opening {APP_NAME}<span class="dots" aria-hidden="true"><span>.</span><span>.</span><span>.</span></span>
        </h1>

        <p class="hero-rise hero-rise-3 mt-3 lead">
          Taking you to the App Store.
        </p>

        <div class="hero-rise hero-rise-4 mt-8 flex flex-col items-center gap-3">
          <a href={APP_STORE_URL} class="cta" rel="noopener">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 384 512" fill="currentColor">
              <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
            </svg>
            <span>Get on the App Store</span>
          </a>
          <a
            href="/"
            class="text-sm font-medium text-[var(--muted)] transition-colors hover:text-[var(--fg)]"
          >
            Back to zerobalance.pro
          </a>
        </div>
      </div>
    </main>

    <style>
      .dots {
        display: inline-block;
        margin-left: 2px;
        letter-spacing: 0.05em;
      }
      .dots > span {
        display: inline-block;
        opacity: 0.2;
        animation: dot-blink 1.2s infinite ease-in-out both;
      }
      .dots > span:nth-child(2) { animation-delay: 0.15s; }
      .dots > span:nth-child(3) { animation-delay: 0.3s; }

      @keyframes dot-blink {
        0%, 80%, 100% { opacity: 0.2; }
        40% { opacity: 1; }
      }

      @media (prefers-reduced-motion: reduce) {
        .dots > span { animation: none; opacity: 1; }
      }
    </style>
  </body>
</html>
