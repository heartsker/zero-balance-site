---
import { APP_ID, APP_NAME } from '../lib/siteConfig';

const APP_STORE_URL = `https://apps.apple.com/app/apple-store/id${APP_ID}?pt=128302223&ct=in-app-event&mt=8`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Opening {APP_NAME}...</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${APP_STORE_URL}`} />
    <script is:inline define:vars={{ APP_STORE_URL }}>
      location.replace(APP_STORE_URL);
    </script>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #faf9fb;
        color: #1c1c1e;
      }
      a {
        color: #7a4de6;
      }
    </style>
  </head>
  <body>
    <p>
      Opening {APP_NAME}... if nothing happens,
      <a href={APP_STORE_URL}>open it on the App Store</a>.
    </p>
  </body>
</html>
