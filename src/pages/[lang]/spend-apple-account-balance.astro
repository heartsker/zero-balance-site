---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import FAQ from '../../components/FAQ.astro';
import Reveal from '../../components/Reveal.astro';
import FinalCta from '../../components/FinalCta.astro';
import { LOCALES, type Locale } from '../../i18n';
import { faqSchema } from '../../lib/schema';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const path = `/${lang}/spend-apple-account-balance/`;

const copy = lang === 'ru'
  ? {
      title: 'Как потратить остаток баланса Apple Account',
      description:
        'Apple не выплачивает остаток баланса деньгами и не разрешает поменять страну, пока баланс не нулевой. Вот как обнулить его без подписок и без потери времени.',
      eyebrow: 'Гайд',
      tldrTitle: 'Коротко',
      tldr:
        'Apple не превращает баланс Apple Account обратно в деньги. Единственный способ потратить остаток - купить что-то в App Store, iTunes или подписке. Zero Balance подбирает ближайшую комбинацию небольших покупок, чтобы свести остаток к нулю за минуту.',
      sections: [
        {
          h: 'Почему Apple не даёт вывести баланс',
          p: 'Баланс Apple Account - это магазинный кредит, а не банковский счёт. Apple указывает в условиях, что баланс невозвратный и тратится только внутри их экосистемы: App Store, iTunes, Apple Books, iCloud, Apple Music и так далее. Поэтому единственная стратегия - его потратить.',
        },
        {
          h: 'Три способа, которыми обычно пробуют его обнулить',
          p: '1) Купить дорогое приложение или подписку и надеяться, что суммы хватит ровно. На практике остаётся остаток в копейках, который потом нельзя потратить.\n\n2) Накопить много мелких покупок руками - утомительно и не точно.\n\n3) Поискать набор покупок, который точно совпадает с остатком - это то, что делает Zero Balance.',
        },
        {
          h: 'Как Zero Balance решает задачу',
          p: 'Внутри Zero Balance восемь ценовых тиров - от очень мелких до средних покупок. Когда вы вводите оставшуюся сумму, приложение находит ближайшую комбинацию из этих тиров, показывает план, общую сумму, превышение (если есть) и количество подтверждений Apple. Подтверждаете покупки - баланс уходит к нулю.',
        },
        {
          h: 'Что делать, если осталось всего несколько копеек',
          p: 'Тогда план превысит сумму ровно на самый маленький тир. Экран проверки плана покажет точное превышение до подтверждения. Если вы готовы заплатить пару копеек сверху, чтобы наконец обнулиться, - вперёд. Если нет - оставьте как есть.',
        },
      ],
      faqLead: 'Связанные вопросы',
      faqItems: [
        {
          q: 'Можно ли получить деньги обратно вместо траты баланса?',
          a: 'Нет. Apple не возвращает баланс Apple Account на банковскую карту. Возможен только возврат конкретной покупки через reportaproblem.apple.com.',
        },
        {
          q: 'Можно ли подарить баланс другому человеку?',
          a: 'Нет, баланс привязан к Apple ID. Подарок возможен только через подарочные карты App Store или подарок конкретного приложения.',
        },
        {
          q: 'Сработает ли это с региональным магазином?',
          a: 'Да. Zero Balance работает с тем магазином App Store, в который вы вошли. Покупки и тиры локализуются автоматически.',
        },
      ],
    }
  : {
      title: 'How to spend leftover Apple Account balance',
      description:
        'Apple does not cash out store credit and will not let you change country while a balance is left. Here is how to clear it down to zero in under a minute, without subscriptions, without wasted time.',
      eyebrow: 'Guide',
      tldrTitle: 'TL;DR',
      tldr:
        'Apple does not convert Apple Account balance back into money. The only way to spend a leftover balance is to buy something inside the App Store, iTunes, or a subscription. Zero Balance picks the closest combination of small App Store items to clear the balance to zero in under a minute.',
      sections: [
        {
          h: 'Why Apple will not let you cash out',
          p: 'Apple Account balance is store credit, not a bank account. Apple\'s terms say the balance is non-refundable and spendable only inside their ecosystem: App Store, iTunes, Apple Books, iCloud, Apple Music, and so on. The only strategy is to spend it down.',
        },
        {
          h: 'Three ways people try this (and which actually work)',
          p: '1) Buy one expensive app or subscription and hope the amount lines up exactly. In practice you almost always end with a few cents stuck. \n\n2) Buy many tiny items manually - tedious and imprecise. \n\n3) Find a combination of purchases that matches the leftover exactly - this is what Zero Balance does.',
        },
        {
          h: 'How Zero Balance does it',
          p: 'Zero Balance offers eight in-app price tiers, from very small to moderate. When you enter your remaining balance, the app finds the closest combination of those tiers, then shows you the plan - total, overage if any, and how many Apple confirmations it will need. Confirm the purchases and your balance trends to zero.',
        },
        {
          h: 'What if only a few cents are left',
          p: 'Then the plan will overshoot by exactly the smallest tier. The plan review screen shows the exact overage before you confirm. If you are okay paying a few cents extra to finally hit zero, go for it. If not, leave it.',
        },
      ],
      faqLead: 'Related questions',
      faqItems: [
        {
          q: 'Can I get the money back instead of spending the balance?',
          a: 'No. Apple does not refund Apple Account balance back to a bank card. You can only refund a specific purchase via reportaproblem.apple.com.',
        },
        {
          q: 'Can I gift my balance to someone else?',
          a: 'No - the balance is tied to your Apple ID. You can only give an App Store gift card or gift a specific app.',
        },
        {
          q: 'Does this work with regional storefronts?',
          a: 'Yes. Zero Balance works with whichever App Store storefront you are signed into. Purchases and tiers are localized automatically.',
        },
      ],
    };
---

<PageLayout
  title={`${copy.title} - Zero Balance`}
  description={copy.description}
  {lang}
  {path}
  schema={faqSchema(copy.faqItems)}
>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />

  <Section>
    <Container>
      <Reveal class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--brand-soft)]/40 p-6 md:p-8">
          <p class="text-sm font-semibold tracking-wide text-[var(--brand-strong)] uppercase">
            {copy.tldrTitle}
          </p>
          <p class="mt-3 text-lg leading-relaxed text-[var(--fg)]">{copy.tldr}</p>
        </div>
      </Reveal>

      <div class="mx-auto mt-10 max-w-3xl prose-zb">
        {
          copy.sections.map((s, i) => (
            <Reveal delay={i * 40}>
              <h2>{s.h}</h2>
              {s.p.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
            </Reveal>
          ))
        }

        <Reveal>
          <h2>{copy.faqLead}</h2>
        </Reveal>
        <Reveal>
          <FAQ items={copy.faqItems} />
        </Reveal>
      </div>
    </Container>
  </Section>

  <FinalCta {lang} />
</PageLayout>
