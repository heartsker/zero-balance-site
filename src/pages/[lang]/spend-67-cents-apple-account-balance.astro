---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import FAQ from '../../components/FAQ.astro';
import Reveal from '../../components/Reveal.astro';
import FinalCta from '../../components/FinalCta.astro';
import AppStoreButton from '../../components/AppStoreButton.astro';
import { getDict, LOCALES, type Locale } from '../../i18n';
import { faqSchema } from '../../lib/schema';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = getDict(lang);
const path = `/${lang}/spend-67-cents-apple-account-balance/`;

const copy = {
  title: 'How to spend $0.67 (or any sub-dollar Apple Account balance)',
  description:
    'Stuck with $0.67 on your Apple Account? Apple\'s smallest in-app purchase is $0.29, so $0.67 cannot be matched exactly without a card on file. Here is how close you can actually get.',
  eyebrow: 'Worked example',
  tldrTitle: 'TL;DR',
  tldr:
    'Apple\'s minimum in-app purchase price is $0.29. With $0.67 you cannot match exactly using only balance: the closest combinations are $0.29 + $0.39 = $0.68 (overshoot $0.01, blocked without a card) or $0.29 = $0.29 leaving $0.38 stuck. Hitting exactly $0.00 requires overshooting with a card on file - e.g. buying a $0.99 song so Apple charges $0.32 to the card.',
  sections: [
    {
      h: 'Why $0.67 is mathematically awkward',
      p: 'Apple\'s App Store uses a discrete set of price points. The smallest in-app purchase tier is $0.29, followed by $0.39 and $0.49, then $0.50 increments going up. There is no $0.01, $0.05, $0.09, or $0.19 IAP tier - those claims appear online but are wrong. Apple expanded the system to 900 price points in late 2022, but the $0.29 floor stayed.\n\nThat $0.29 floor is what makes $0.67 hard. You cannot split $0.67 into a sum of available IAP prices without overshooting or leaving a residue smaller than $0.29 - and a residue smaller than $0.29 cannot be spent because no IAP is that cheap.',
    },
    {
      h: 'Closest combinations using only your balance',
      p: 'If you have no credit or debit card on the account (common for accounts funded entirely by gift cards), here are the realistic options:\n\n- Buy one $0.29 IAP. New balance: $0.38. The $0.38 is now stuck because no smaller IAP exists.\n- Buy $0.29 + $0.29 = $0.58. New balance: $0.09. Stuck for the same reason.\n- Try to combine for $0.67 exactly: impossible. The closest you can reach is $0.68 ($0.29 + $0.39) which would overshoot by $0.01 - and without a card, the App Store will refuse the purchase because there is no way to charge the $0.01.\n\nIn short: without a card on file, $0.67 reduces to "spend what you can, accept a few cents stuck."',
    },
    {
      h: 'The clean path: overshoot with a card on file',
      p: 'If you have a credit or debit card on the Apple Account, this is the only way to hit exactly $0.00:\n\n1. Buy a $0.99 song from the iTunes Store, or any $0.99 paid app or in-app purchase.\n2. Apple debits your $0.67 balance first, then charges the remaining $0.32 to your card.\n3. Your balance is now $0.00 to the cent.\n\nIf $0.99 feels like too much overshoot, you can do the same trick with any $0.79, $0.89, or $0.69 IAP if you find one priced that way - the balance always pays first.',
    },
    {
      h: 'Where Zero Balance fits in',
      p: 'Zero Balance is a free iOS app I built specifically for this kind of awkward leftover amount. The app ships with its own 10 small in-app purchases - Cosmic Cocoa $0.29, Nebula Nibbles $0.39, Star Sprinkles $0.49, Galaxy Feast $0.79, Sunbeam Patch $0.90, Toast Pebble $0.95, Hearth Orb $1.00, Giggle Bubble $1.09, Meteor Pop $1.19, and Cozy Pin $1.49.\n\nYou enter your remaining balance (e.g. $0.67), and the algorithm finds the combination of these tiers that lands closest to that amount. The plan-review screen always shows the exact overage and the number of Apple confirmation prompts before any purchase is made. Apple\'s $0.29 floor still applies - for residuals smaller than that, you will see a small overage shown clearly on the review screen.\n\nNo Apple ID login, no ads, no tracking, no subscription. Inventory syncs privately to your own iCloud.',
    },
    {
      h: 'What does not work for $0.67',
      p: 'A few things people try that won\'t help:\n\n- Apple Support will not refund $0.67 to a bank card or convert it to cash. Apple Account balance is non-refundable, non-transferable store credit by Apple\'s terms.\n- You cannot transfer it to Apple Pay. Apple Pay funds and store credit are different instruments and cannot be moved between each other.\n- You cannot buy an Apple Gift Card with your balance. Apple disabled this around 2019 to prevent fraud laundering.\n- Third-party "iTunes-to-cash" sites are uniformly either scams or take a 20-30% cut. Avoid them.',
    },
  ],
  faqLead: 'Related questions',
  faqItems: [
    {
      q: 'Is there really no $0.09 or $0.19 IAP tier?',
      a: 'Correct. Apple\'s minimum in-app purchase price is $0.29. See Apple\'s December 2022 announcement on the 900-price-point expansion for the canonical source.',
    },
    {
      q: 'Will Apple Support just zero out my $0.67 if I ask?',
      a: 'Generally no, unless you are explicitly trying to change your Apple ID country and have already reduced the balance below the unofficial ~$0.69 threshold. For a casual cleanup request, expect them to tell you to spend it.',
    },
    {
      q: 'Does Zero Balance read my Apple Account balance automatically?',
      a: 'No. You type the amount in yourself. The app never has access to your Apple ID, your purchase history, or your balance.',
    },
  ],
};
---

<PageLayout
  title={`${copy.title} - Zero Balance`}
  description={copy.description}
  {lang}
  {path}
  schema={faqSchema(copy.faqItems)}
  ogType="article"
  keywords={[...t.keywords.remove, ...t.keywords.site]}
>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />

  <Section>
    <Container>
      <Reveal class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--brand-soft)]/40 p-6 md:p-8">
          <p class="text-sm font-semibold tracking-wide text-[var(--brand-strong)] uppercase">
            {copy.tldrTitle}
          </p>
          <p class="mt-3 text-lg leading-relaxed text-[var(--fg)]">{copy.tldr}</p>
          <div class="mt-6 flex">
            <AppStoreButton label={t.cta.appStore} ct="outreach-quora-67cents" />
          </div>
        </div>
      </Reveal>

      <div class="mx-auto mt-10 max-w-3xl prose-zb">
        {
          copy.sections.map((s, i) => (
            <Reveal delay={i * 40}>
              <h2>{s.h}</h2>
              {s.p.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
              {i === 3 && (
                <div class="not-prose my-6 flex">
                  <AppStoreButton label={t.cta.appStore} ct="outreach-quora-67cents-mid" />
                </div>
              )}
            </Reveal>
          ))
        }

        <Reveal>
          <h2>{copy.faqLead}</h2>
        </Reveal>
        <Reveal>
          <FAQ items={copy.faqItems} />
        </Reveal>
      </div>
    </Container>
  </Section>

  <FinalCta {lang} />
</PageLayout>
