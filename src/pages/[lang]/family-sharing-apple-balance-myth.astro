---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import FAQ from '../../components/FAQ.astro';
import Reveal from '../../components/Reveal.astro';
import FinalCta from '../../components/FinalCta.astro';
import AppStoreButton from '../../components/AppStoreButton.astro';
import { getDict, LOCALES, type Locale } from '../../i18n';
import { faqSchema } from '../../lib/schema';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = getDict(lang);
const path = `/${lang}/family-sharing-apple-balance-myth/`;

const copy = {
  title: 'Can you transfer Apple ID balance through Family Sharing?',
  description:
    'Family Sharing does not share Apple Account balance - here is what it actually shares, why the myth persists, and what really clears leftover credit.',
  eyebrow: 'Myth debunk',
  tldrTitle: 'TL;DR',
  tldr:
    'No. Apple Account balance is not shared, transferred, or pooled through Family Sharing. Each family member\'s balance is locked to their own Apple ID. Family Sharing shares purchased apps, Apple Music, iCloud Storage, and subscriptions - but never store credit. If you came here from a forum thread that confidently said otherwise, the answer was wrong.',
  sections: [
    {
      h: 'Where the myth comes from',
      p: 'Three sources mix together:\n\n1. Old Apple documentation described "Family Sharing" alongside "Ask to Buy" and "purchase sharing", and casual readers conflated them.\n\n2. Quora and Apple Discussions answers from 2017-2020 sometimes said balance was shareable. It wasn\'t even then, but the answers got upvoted and copied.\n\n3. Generative AI responses trained on those old forum posts repeat the myth with full confidence.\n\nThe myth has staying power because Family Sharing does share a lot. It just doesn\'t share this one specific thing.',
    },
    {
      h: 'What Family Sharing actually shares',
      p: 'When you set up Family Sharing, these things become available to all family members:\n\n- Purchased apps, music, movies, TV shows, and books (subject to per-item DRM rules).\n\n- Apple Music family plan (up to 6 members).\n\n- iCloud Storage (the family organizer\'s plan).\n\n- Apple TV+, Apple Arcade, Apple News+, Apple Fitness+ (when paid for via the organizer).\n\n- Apple One bundle.\n\n- Location sharing, Screen Time, Ask to Buy (parental controls).\n\n- A shared payment method for kids\' purchases (organizer\'s card).\n\n- Photos via Shared Library.\n\nThat\'s a long list. It looks like everything. The exception is small but absolute.',
    },
    {
      h: 'What Family Sharing does NOT share',
      p: '- Apple Account balance and store credit. Each Apple ID has its own balance. There is no setting, no toggle, no admin tool that lets one member spend another\'s balance.\n\n- iCloud Drive personal files (Shared Library is photos only).\n\n- App Store country (each member can be in a different region).\n\n- Subscriptions purchased outside the family plan.',
    },
    {
      h: 'Why this matters for the change-region flow',
      p: 'The biggest practical impact of the myth: people trying to change their App Store country see "use Family Sharing to spend the balance" and waste an afternoon trying to make it work. Here is what actually happens:\n\n1. You add a family member.\n2. They go to buy something, hoping it will pull from your balance.\n3. Apple charges their balance and payment method, not yours.\n4. Your balance sits unchanged. The region change is still blocked.\n\nYou haven\'t moved a cent. You\'ve just added a family member you didn\'t need.',
    },
    {
      h: 'Apple\'s official position',
      p: 'Apple\'s Family Sharing support page lists what is shared. Apple Account balance is not on the list. Apple\'s region-change page tells you the balance must be zero - it does not suggest Family Sharing as a workaround.\n\nIf a single official Apple document mentioned balance sharing, it would be the most-linked support page on the internet. None does.',
    },
    {
      h: 'What actually works',
      p: 'You have three real options to clear the balance:\n\n1. Ask Apple Support to zero it out. Most reliable for small leftovers under $1. See the full Apple Support script at /' + lang + '/alternatives/.\n\n2. Spend it down to zero manually. Works if you have a payment method and can find an item priced near your balance. Walkthrough at /' + lang + '/spend-apple-account-balance/.\n\n3. Use a utility built for this case. Zero Balance auto-picks a combination of small in-app items that adds up to your leftover. 60-90 seconds. Free.\n\nOnce the balance is $0.00, the region change unblocks. The Family Sharing detour adds nothing.',
    },
  ],
  faqLead: 'Related questions',
  faqItems: [
    {
      q: 'Can the family organizer\'s payment method cover a member\'s balance shortfall?',
      a: 'The organizer\'s card can be charged for a family member\'s purchase (via Ask to Buy or shared payment). The organizer\'s balance is never touched. Card and balance are separate things.',
    },
    {
      q: 'What if I transfer my Apple ID itself to a family member?',
      a: 'You can\'t. Apple IDs are non-transferable. Each Apple ID stays with its original owner.',
    },
    {
      q: 'Is there any way to combine balances across two Apple IDs?',
      a: 'No. The only "combining" is when you redeem additional gift cards into the same Apple ID - that adds to the existing balance for that one account.',
    },
    {
      q: 'My family member said it worked for them. Are they lying?',
      a: 'They probably bought something with their own balance, and the timing made it look like yours moved. Check your own balance in Settings - it has not changed.',
    },
    {
      q: 'Will Apple ever change this?',
      a: 'Unlikely. Balance is tied to a storefront and to a specific Apple ID for tax and refund-policy reasons. Apple has shown no movement toward shared balance in any recent OS release.',
    },
  ],
};
---

<PageLayout
  title={`${copy.title} - Zero Balance`}
  description={copy.description}
  {lang}
  {path}
  schema={faqSchema(copy.faqItems)}
  ogType="article"
  keywords={[...t.keywords.alternatives, ...t.keywords.site]}
>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />

  <Section>
    <Container>
      <Reveal class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--brand-soft)]/40 p-6 md:p-8">
          <p class="text-sm font-semibold tracking-wide text-[var(--brand-strong)] uppercase">
            {copy.tldrTitle}
          </p>
          <p class="mt-3 text-lg leading-relaxed text-[var(--fg)]">{copy.tldr}</p>
          <div class="mt-6 flex">
            <AppStoreButton label={t.cta.appStore} ct="outreach-family-sharing-myth" />
          </div>
        </div>
      </Reveal>

      <div class="mx-auto mt-10 max-w-3xl prose-zb">
        {
          copy.sections.map((s, i) => (
            <Reveal delay={i * 40}>
              <h2>{s.h}</h2>
              {s.p.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
              {i === 5 && (
                <div class="not-prose my-6 flex">
                  <AppStoreButton label={t.cta.appStore} ct="outreach-family-sharing-myth-mid" />
                </div>
              )}
            </Reveal>
          ))
        }

        <Reveal>
          <h2>{copy.faqLead}</h2>
        </Reveal>
        <Reveal>
          <FAQ items={copy.faqItems} />
        </Reveal>
      </div>
    </Container>
  </Section>

  <FinalCta {lang} />
</PageLayout>
