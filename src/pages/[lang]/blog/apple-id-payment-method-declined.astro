---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Container from '../../../components/Container.astro';
import Section from '../../../components/Section.astro';
import FAQ from '../../../components/FAQ.astro';
import Reveal from '../../../components/Reveal.astro';
import FinalCta from '../../../components/FinalCta.astro';
import AppStoreButton from '../../../components/AppStoreButton.astro';
import { getDict, LOCALES, type Locale } from '../../../i18n';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../../lib/schema';
import { DOMAIN } from '../../../lib/siteConfig';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = getDict(lang);
const slug = 'apple-id-payment-method-declined';
const path = `/${lang}/blog/${slug}/`;
const published = '2026-05-19T00:00:00Z';

const copy = {
  title: 'Apple ID payment method declined: full troubleshooting guide',
  description:
    'Your card works everywhere else but Apple keeps declining it. Here is why Apple\'s auth flow fails on cards your bank otherwise approves, and how to fix it.',
  eyebrow: 'Payment issues',
  tldr:
    'Apple authorizes a small charge (often $1) to verify the card; if your bank blocks pre-auth charges, Apple shows "declined" even though there is nothing wrong with the card. Call your bank to allow Apple pre-auths, then re-add the card.',
  sections: [
    {
      h: 'Why Apple shows "declined" on a card your bank approves',
      p: 'Apple does not just store the card and trust it. Every time you add or update a payment method, Apple submits a small authorization charge to validate the card. The charge is usually $1 USD equivalent (sometimes a different small amount in other currencies). It is not captured - it is released back to the card after a few days.\n\nMany banks block these no-billing-address auths by default, especially:\n\n- International transactions if you have international purchases disabled.\n- Pre-auth-without-capture charges, which some banks treat as suspicious.\n- Card-not-present transactions from a merchant the bank does not recognize.\n- Cards with $0 or $1 transactions disabled (a fraud rule some banks apply automatically).\n\nFrom your perspective, the card "works everywhere else" because regular merchants do a full capture, not a pre-auth. Apple\'s pre-auth is a different flavor of transaction and triggers different bank rules.\n\nThe Apple "declined" message does not mean the card has no balance, is expired, or is genuinely broken. It means the auth was rejected, which is often a bank-side fraud rule rather than the card itself.',
    },
    {
      h: 'Billing address mismatch and country mismatch',
      p: 'The second-most-common cause: address validation.\n\nApple checks the billing address you enter against the address your bank has on file. If they do not match exactly (street number format, postal code format, apartment number), the auth fails. "Declined" is the same generic message you get for the bank-side fraud rules.\n\nCommon mismatches:\n\n- UK postcodes with vs without a space (SW1A1AA vs SW1A 1AA).\n- US ZIP+4 vs 5-digit ZIP.\n- Street numbers as letters (apartment 2A vs apartment 2-A).\n- Special characters or umlauts in non-English addresses that Apple\'s form rejects.\n\nCountry mismatch is more fundamental:\n\n- US-issued Visa cannot be used on a UK Apple ID. The card country must match the Apple ID country.\n- Some sub-categories within a country: a US Apple ID needs a US-issued card (Mexican-issued Visas often fail on the US storefront even though Mexico is a Visa country).\n\nFix: either change the Apple ID country to match the card, or get a card issued in the storefront country.',
    },
    {
      h: '3D Secure and strong customer authentication',
      p: 'For European cards and cards from regions that have adopted Strong Customer Authentication (SCA), Apple\'s payment flow includes a 3D Secure step. The bank pushes a verification request to the bank\'s app (or sends an SMS) asking you to confirm the Apple charge.\n\nIf you do not see the 3D Secure prompt, or it times out before you respond, Apple shows "declined". The card is fine; the auth flow did not complete.\n\nWhere this breaks:\n\n- Bank app not installed on the device you are using to add the card.\n- Bank app notifications muted or not arriving.\n- Push notifications delayed by minutes (slow operator network).\n- 3D Secure SMS sent to a phone number you no longer use.\n- Bank session expired in the bank app, requiring re-login before you can approve.\n\nThe fix is to make sure the 3D Secure path is ready to receive prompts before you tap Add Payment Method. Open the bank app first, make sure you are logged in, make sure notifications work, then go to Apple\'s flow. Tap "Add Payment Method", expect the bank prompt within seconds, approve immediately.',
    },
    {
      h: 'Card type restrictions per region',
      p: 'Some card types are accepted by App Store but rejected by other Apple flows, and vice versa. Categories that have known issues:\n\n- Prepaid cards: most major brands now accept these for App Store, but Apple Developer enrollment, AppleCare+ subscriptions, and Apple Card application all reject them.\n\n- Virtual / disposable cards from fintech providers (Revolut virtual, Wise virtual, Privacy.com): App Store usually accepts; Apple Developer and Apple Online Store sometimes reject.\n\n- Corporate cards: some are restricted from consumer-product purchases by the card issuer. The card declines Apple specifically while approving Amazon.\n\n- Cards under daily online-spend limits: Apple Developer enrollment charges $99 USD up-front; if your card has a $50/day online-spend ceiling, the charge declines.\n\n- Russian Mir cards, Chinese UnionPay (in some regions), and Turkish Troy cards: limited Apple support, varies by storefront.\n\nThe fix: try a different card. A standard issuer-bank credit or debit card (Visa, Mastercard, Amex) from a major bank, with the billing country matching the Apple ID country, works in almost all cases.',
    },
    {
      h: 'What to try, in order',
      p: 'When everything fails, the practical sequence:\n\n1. Call the bank for each card. Ask them to whitelist Apple pre-authorization charges. Use those exact words; bank reps know what they mean. This fixes 60-70% of failures.\n\n2. Try Apple Pay instead of card-on-file. Apple Pay uses a different auth path (tokenized, no pre-auth). Often succeeds when card-on-file fails.\n\n3. Try PayPal as an Apple payment method if your region supports it. PayPal handles the auth itself; Apple is just receiving the funds.\n\n4. As a workaround for buying something specific: redeem a small Apple gift card to seed the balance. App Store purchases run from balance first; if the balance covers the purchase, no card is touched. This sidesteps the auth issue entirely for the duration of the balance.\n\n5. If you need a card for subscriptions (which need a recurring payment method), use one that supports Apple\'s auth - Apple Pay backed by a major-issuer card is the most reliable combination.\n\n6. Last resort: contact iTunes Store support. They can sometimes diagnose the specific bank decline code Apple received and tell you what to ask the bank to change.',
    },
  ],
  faqItems: [
    {
      q: 'Why did Apple charge me $1 on a card I never used?',
      a: 'That is the pre-authorization charge Apple uses to validate the card. It is not captured - it should release back to the card within 3-7 business days. If it hasn\'t released after 10 days, contact your bank to ask them to release the pending auth.',
    },
    {
      q: 'My card was added successfully a year ago but Apple now declines it on every renewal. What changed?',
      a: 'Usually a fraud rule activated on the card. Banks periodically tighten their rules and existing relationships sometimes get caught up. Call the bank, ask them to allow Apple pre-auths and recurring charges, then trigger a small purchase to revalidate.',
    },
    {
      q: 'Can I use a friend\'s card to add a payment method to my Apple ID?',
      a: 'You can, but the billing address must match the cardholder, not you. Apple validates against the bank record. If the addresses do not match, the auth fails.',
    },
    {
      q: 'Apple Developer rejected my card. The App Store accepts the same card. Why?',
      a: 'Developer enrollment runs a stricter validator (full legal name match, full address match, higher charge amount). Standard App Store accepts more variations. The fix is either to fix the mismatch (often a name typo in the developer agreement) or use a different card that passes the stricter check.',
    },
    {
      q: 'Should I just remove all payment methods and try fresh?',
      a: 'It rarely helps. The state Apple cares about is not local - it is the auth history with your bank. Removing and re-adding the same card triggers the same auth path and usually fails the same way. Fix the bank-side rule first.',
    },
  ],
};
---

<PageLayout
  title={`${copy.title} - Zero Balance`}
  description={copy.description}
  {lang}
  {path}
  schema={[
    articleSchema({ title: copy.title, description: copy.description, slug, lang, datePublished: published }),
    faqSchema(copy.faqItems),
    breadcrumbSchema([
      { name: 'Home', url: `${DOMAIN}/${lang}/` },
      { name: 'Blog', url: `${DOMAIN}/${lang}/blog/` },
      { name: copy.title, url: `${DOMAIN}${path}` },
    ]),
  ]}
  ogType="article"
  publishedTime={published}
  modifiedTime={published}
  keywords={[
    'apple id payment method declined',
    'card declined apple',
    'payment authorization failed apple',
    'apple pre auth charge',
    'apple billing address rejected',
    ...t.keywords.support,
  ]}
>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />

  <Section>
    <Container>
      <Reveal class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--brand-soft)]/40 p-6 md:p-8">
          <p class="text-sm font-semibold tracking-wide text-[var(--brand-strong)] uppercase">TL;DR</p>
          <p class="mt-3 text-lg leading-relaxed text-[var(--fg)]">{copy.tldr}</p>
          <div class="mt-6 flex">
            <AppStoreButton label={t.cta.appStore} ct="blog-payment-declined-tldr" />
          </div>
        </div>
      </Reveal>

      <div class="mx-auto mt-10 max-w-3xl prose-zb">
        {
          copy.sections.map((s, i) => (
            <Reveal delay={i * 40}>
              <h2>{s.h}</h2>
              {s.p.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
              {i === 4 && (
                <div class="not-prose my-6 flex">
                  <AppStoreButton label={t.cta.appStore} ct="blog-payment-declined-mid" />
                </div>
              )}
            </Reveal>
          ))
        }

        <Reveal>
          <h2>Related questions</h2>
        </Reveal>
        <Reveal>
          <FAQ items={copy.faqItems} />
        </Reveal>
      </div>
    </Container>
  </Section>

  <FinalCta {lang} />
</PageLayout>
