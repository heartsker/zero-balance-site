---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Container from '../../../components/Container.astro';
import Section from '../../../components/Section.astro';
import FAQ from '../../../components/FAQ.astro';
import Reveal from '../../../components/Reveal.astro';
import FinalCta from '../../../components/FinalCta.astro';
import AppStoreButton from '../../../components/AppStoreButton.astro';
import { getDict, LOCALES, type Locale } from '../../../i18n';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../../lib/schema';
import { DOMAIN } from '../../../lib/siteConfig';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = getDict(lang);
const slug = 'apple-gift-card-for-in-app-purchases';
const path = `/${lang}/blog/${slug}/`;
const published = '2026-05-19T00:00:00Z';

const copy = {
  title: 'Can you use an Apple gift card for in-app purchases?',
  description:
    'Yes, App Store gift cards pay for in-app purchases - but only one of the two Apple gift card types. Here is which works, which does not, and the gotchas.',
  eyebrow: 'Gift cards',
  tldr:
    'Yes, Apple Gift Cards (the App Store & iTunes kind) can pay for in-app purchases. The Apple Store gift card - which is for hardware - cannot. The two look similar; check the back of the card or the email for the wording before redeeming.',
  sections: [
    {
      h: 'Yes: Apple gift cards work for IAPs',
      p: 'Once you redeem an Apple Gift Card (App Store & iTunes / Apple Account variety), the value becomes part of your Apple Account balance. Apple Account balance is fungible across every digital purchase Apple processes - paid apps, in-app purchases, subscriptions, Apple Music, Apple TV+, Apple One, iCloud+, books, movies, AppleCare+, and Apple hardware via the Apple Store iPhone app in supported regions.\n\nWhen you tap "Buy" on any in-app purchase, Apple deducts from the balance first and falls back to your payment method only when the balance does not cover the amount. There is no setting to flip and no menu to choose - the order is automatic.\n\nThis applies to first-party apps (Apple\'s own subscriptions) and third-party apps equally. Robux in Roblox, gem packs in Clash of Clans, in-game currency in Genshin Impact, ad-removal IAPs in indie apps - all debit your balance the same way.',
    },
    {
      h: 'No: Apple Store gift cards do not work',
      p: 'Apple sells two distinct gift card products with confusingly similar packaging:\n\n1. Apple Gift Card (sometimes called "App Store & iTunes Gift Card" in older inventory). For digital purchases. Code is 16 characters starting with X. Redeems via Settings -> Redeem Gift Card or Code or via the App Store app. Funds go to Apple Account balance.\n\n2. Apple Store gift card. For Apple retail (hardware, accessories, services). Code is different format. Redeems only at apple.com online checkout or in Apple Store retail locations. Does NOT redeem in the App Store, does NOT add to Apple Account balance, and CANNOT pay for IAPs.\n\nThe physical cards look almost identical. Apple consolidated them under the "Apple Gift Card" name in 2021 in some regions, making the situation more confusing. Always check the small print on the back of the card or the email subject line if it was digital. The redemption flow tells you immediately - if the code is rejected by the App Store, you almost certainly have the Apple Store retail card.',
    },
    {
      h: 'How to tell the two apart',
      p: 'Quick checks before you buy or redeem:\n\nPhysical card:\n- Look at the small print on the back. App Store & iTunes Gift Card / Apple Gift Card (the digital one) explicitly mentions apps, music, books, subscriptions, iCloud.\n- The Apple Store gift card mentions Apple retail, hardware, AppleCare, in-store pickup.\n- The code length and format differ slightly. The App Store card code begins with X.\n\nDigital card (email):\n- Subject line. "Your Apple Gift Card is ready" / "Your App Store & iTunes Gift Card" = digital. "Your Apple Store Gift Card" = retail.\n- Body text. The digital card email links to redeem at apps.apple.com/redeem. The retail card links to apple.com/shop/giftcard.\n\nIn online shopping:\n- Amazon, Walmart, Costco, etc. list both products. Read the product title carefully. "Apple App Store & iTunes Gift Card" vs "Apple Store Gift Card" - small wording difference, big functional difference.\n\nIf you have already redeemed and the code does not show up in your Apple Account balance, you have the wrong card type. The good news: you can still use the Apple Store gift card for Apple hardware. The bad news: you cannot convert it to the digital one.',
    },
    {
      h: 'Redeeming the right card',
      p: 'For the App Store / Apple Gift Card type, three ways to redeem:\n\n1. iPhone Settings: Settings -> [your name] -> Redeem Gift Card or Code. Use camera to scan the code or type it manually. Funds appear in balance within seconds.\n\n2. App Store app: tap your profile picture (top right) -> Redeem Gift Card or Code. Same flow as Settings, same result.\n\n3. Web: redeem.apple.com or the link in the digital gift card email. Sign in with the Apple ID you want to credit. Enter the code. Funds appear within minutes.\n\nThe code is locked to the country of the storefront. A US Apple Gift Card cannot be redeemed on a UK Apple ID and vice versa. If you receive a gift card from someone in a different country, the gifter has to buy a card from your country\'s store - cards do not convert across borders.\n\nAfter redeeming, the balance is immediately available for any digital purchase, including IAPs. Apple deducts from balance automatically when you confirm a purchase.',
    },
    {
      h: 'Why a redeemed balance might not be used automatically',
      p: 'Rare but real: you redeem a gift card, the balance shows in Settings, but a subsequent purchase charges your card instead of using the balance. Causes:\n\n- The purchase ran under a different Apple ID. Settings -> Media & Purchases shows which Apple ID is processing App Store purchases; that is the one Apple checks the balance on. If you redeemed on Apple ID A but Media & Purchases is signed into Apple ID B, the balance Apple sees is B\'s balance (which has nothing in it).\n\n- The purchase is a Family Sharing subscription where the family payer\'s card covers it. The buyer\'s balance is not touched - the organizer\'s card is.\n\n- The balance is locked to a different storefront than the current one. You redeemed a US gift card; later you changed Apple ID country; the old US balance does not apply on the new storefront.\n\n- The balance is disabled (Apple\'s fraud system flagged it). Settings shows the amount but the purchase flow refuses to use it.\n\nDiagnosis: check Settings -> Media & Purchases -> View Account on the device where the purchase happened. If the balance shown there is what you expected, the purchase should have used it. If it does not, contact iTunes Store support with the receipt and the balance screen open.',
    },
    {
      h: 'Game-specific edge cases',
      p: 'Some games have additional restrictions that interact with the balance:\n\n- Region-locked in-game offers. Genshin Impact, for instance, sells different items at different prices in different regions. The IAP itself runs through Apple, so the balance works, but the game might not show the item at all if the device region does not match the account region.\n\n- Anti-cheat / anti-fraud rules in the game. Roblox, Supercell games, and others sometimes flag rapid IAP purchases on a new account as suspicious and refuse to deliver the currency. The balance still gets debited; the in-game outcome is the publisher\'s problem, not Apple\'s.\n\n- Family-organized games (kids\' devices via Ask to Buy). The purchase prompts on the kid\'s device but bills the parent\'s account. The kid\'s balance is not touched.\n\n- Subscription bundles within games (Fortnite Crew when it was on iOS, certain mobile MMO subscriptions). These run through Apple\'s subscription system, so balance applies. Whether the game continues to offer the subscription depends on the publisher\'s contract with Apple.',
    },
  ],
  faqItems: [
    {
      q: 'Can I redeem multiple Apple Gift Cards to get a bigger IAP balance?',
      a: 'Yes. Apple Gift Cards stack. Redeem each separately and the totals add to your Apple Account balance. There is no limit on how many you can redeem.',
    },
    {
      q: 'Will my balance buy a subscription that auto-renews?',
      a: 'Yes for the first cycle (and subsequent cycles as long as balance covers the renewal price). When the balance runs out, Apple charges the payment method on file. If there is no payment method on file, the subscription pauses and Apple emails you to add one.',
    },
    {
      q: 'Does the balance from a gift card expire?',
      a: 'No. Apple Account balance does not expire. It sits indefinitely until you spend it.',
    },
    {
      q: 'Can I gift a balance from my Apple ID to someone else?',
      a: 'Not directly. You can buy a new Apple Gift Card and send it (via Apple\'s digital gift card flow) but the new card is charged to your card, not deducted from your balance. Apple disabled the "balance to gift card" path in 2019 to prevent fraud laundering.',
    },
    {
      q: 'What if my Apple Gift Card balance is awkward (like $0.78) and no single IAP matches it?',
      a: 'Either overshoot with a card on file (buy an item priced above the leftover, Apple uses balance first and charges card the rest), or stack small consumable IAPs. The [Zero Balance app](https://apps.apple.com/app/apple-store/id6761912988?pt=128302223&ct=zerobalance-pro-site&mt=8) is built for the second case.',
    },
  ],
};
---

<PageLayout
  title={`${copy.title} - Zero Balance`}
  description={copy.description}
  {lang}
  {path}
  schema={[
    articleSchema({ title: copy.title, description: copy.description, slug, lang, datePublished: published }),
    faqSchema(copy.faqItems),
    breadcrumbSchema([
      { name: 'Home', url: `${DOMAIN}/${lang}/` },
      { name: 'Blog', url: `${DOMAIN}/${lang}/blog/` },
      { name: copy.title, url: `${DOMAIN}${path}` },
    ]),
  ]}
  ogType="article"
  publishedTime={published}
  modifiedTime={published}
  keywords={[
    'apple gift card in app purchase',
    'gift card for in app purchases ios',
    'redeem apple gift card game',
    'apple gift card iap',
    'apple store vs app store gift card',
    ...t.keywords.leftoverGiftCard,
  ]}
>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />

  <Section>
    <Container>
      <Reveal class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--brand-soft)]/40 p-6 md:p-8">
          <p class="text-sm font-semibold tracking-wide text-[var(--brand-strong)] uppercase">TL;DR</p>
          <p class="mt-3 text-lg leading-relaxed text-[var(--fg)]">{copy.tldr}</p>
          <div class="mt-6 flex">
            <AppStoreButton label={t.cta.appStore} ct="blog-giftcard-iap-tldr" />
          </div>
        </div>
      </Reveal>

      <div class="mx-auto mt-10 max-w-3xl prose-zb">
        {
          copy.sections.map((s, i) => (
            <Reveal delay={i * 40}>
              <h2>{s.h}</h2>
              {s.p.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
              {i === 4 && (
                <div class="not-prose my-6 flex">
                  <AppStoreButton label={t.cta.appStore} ct="blog-giftcard-iap-mid" />
                </div>
              )}
            </Reveal>
          ))
        }

        <Reveal>
          <h2>Related questions</h2>
        </Reveal>
        <Reveal>
          <FAQ items={copy.faqItems} />
        </Reveal>
      </div>
    </Container>
  </Section>

  <FinalCta {lang} />
</PageLayout>
