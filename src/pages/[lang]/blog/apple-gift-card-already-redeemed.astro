---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Container from '../../../components/Container.astro';
import Section from '../../../components/Section.astro';
import FAQ from '../../../components/FAQ.astro';
import Reveal from '../../../components/Reveal.astro';
import FinalCta from '../../../components/FinalCta.astro';
import AppStoreButton from '../../../components/AppStoreButton.astro';
import { getDict, LOCALES, type Locale } from '../../../i18n';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../../lib/schema';
import { DOMAIN } from '../../../lib/siteConfig';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = getDict(lang);
const slug = 'apple-gift-card-already-redeemed';
const path = `/${lang}/blog/${slug}/`;
const published = '2026-05-19T00:00:00Z';

const copy = {
  title: 'Apple gift card "already redeemed": what to try before giving up',
  description:
    'Your Apple gift card code shows as already redeemed by someone else. Here is what really happened, who to contact, and the realistic recovery odds.',
  eyebrow: 'Gift cards',
  tldr:
    'This usually means scammers harvested the code in-store before you bought the card. Contact Apple iTunes Store support with your receipt and the card serial number; if Apple confirms the activation but says the code is used, return to the retailer for a refund - they activated a tampered card.',
  sections: [
    {
      h: 'The two real causes',
      p: 'When Apple says "this code has already been redeemed" on a card you just bought, two things actually happened:\n\n1. In-store code harvesting. Scammers visit the retailer, photograph or scan the redemption codes through the foil scratch-off layer (it is thin enough to read through with the right tool), then wait for the cards to be activated by paying customers. The moment a card is activated at the register, the scammer redeems the code remotely within seconds. By the time you scratch off the foil and try to redeem, the code is gone.\n\n2. The card was never activated. The cashier scanned the card but the POS transaction failed silently, or the retailer\'s gift-card activation system was offline at the moment of purchase. The card has no value to anyone - including the scammers - because activation never happened. The "already redeemed" error is misleading; the underlying code state is "never funded".\n\nThe two have different recovery paths. The first is usually a retailer issue (the retailer activated a compromised card, so they refund you and chase the scammer). The second is a retailer activation issue (the retailer never actually charged the card with money, so they have to fix the POS issue and re-activate or refund).',
    },
    {
      h: 'First check: receipt and serial number',
      p: 'Before contacting anyone, gather two pieces of evidence:\n\n- The receipt from the purchase. The gift card activation line shows on the receipt as a separate transaction with the dollar value. If you do not see that line, the card was never activated.\n\n- The serial number on the back of the card. It is a 16-19 digit number printed on the back, separate from the redemption code. The serial is not what you redeem with; it identifies the card itself.\n\nWith both, you can check:\n\n- Receipt has activation line + correct dollar amount: cause #1 (in-store harvesting). Recovery via Apple support or the retailer.\n\n- Receipt has no activation line: cause #2 (never activated). Recovery via the retailer; they need to fix their POS or re-activate the card.\n\n- Receipt is missing entirely: harder. You need to return to the retailer with whatever proof of purchase you have (credit card statement showing the charge) and have them look up the transaction.\n\nDo not throw away the gift card itself even though you cannot use it. The serial number on the back is what Apple support needs.',
    },
    {
      h: 'The chain of responsibility',
      p: 'The fraud pattern involves multiple parties. Knowing who is responsible for what helps target the right channel:\n\nThe retailer: responsible for activating cards securely. Cards on the rack should be unactivated until checkout. Once a card is activated, the retailer is on the hook for delivering working value to the buyer.\n\nApple: responsible for honoring valid redemption codes. Once a code is redeemed by someone, Apple\'s database marks it used. Apple cannot un-redeem a code, but Apple can sometimes credit the rightful buyer if the chain of custody points to retailer activation of a tampered card.\n\nThe buyer (you): responsible for inspecting the card at purchase and reporting the issue promptly. Some retailers have time limits on gift card refunds (often 30-60 days from purchase, sometimes shorter).\n\nThe scammer: responsible for the actual fraud. The retailer and Apple both pursue these patterns. The buyer rarely interacts with the scammer at all.\n\nThe practical implication: pursue the retailer first if you have a receipt. They are legally on the hook (in most US states, courts have held retailers liable for selling tampered gift cards) and have the most direct fix path - just refund you. Apple is the second step if the retailer refuses or you bought without a receipt.',
    },
    {
      h: 'Contacting Apple iTunes Store support',
      p: 'When you need Apple\'s side of the recovery (typically because the retailer denied a refund), the channel is iTunes Store support, not general AppleCare. Route:\n\n1. getsupport.apple.com -> "Apple Account" -> "Apple Gift Card" -> Request a callback or chat.\n2. AppleCare chat agents will direct you to iTunes Store specifically - the gift card team is a different group.\n\nBring to the call:\n\n- Date and approximate time of purchase.\n- Retailer name and store location.\n- Receipt (photo is fine).\n- Card serial number (16-19 digits on the back).\n- Date you attempted to redeem and the exact error message.\n- A photo of the back of the card showing the scratch-off layer (intact or scratched).\n- Bank statement showing the gift card purchase (helpful but not required if you have the receipt).\n\nWhat Apple does:\n\n- Looks up the card by serial number. Confirms whether it was activated, whether it was redeemed, and approximately when.\n- If activated and redeemed by someone other than you on the same day as your purchase: strong evidence of in-store harvesting. Apple sometimes (not always) credits your account with the equivalent value.\n- If never activated: Apple cannot help; the retailer must fix the activation issue.\n- If activated and redeemed long after your purchase: trickier. Apple cannot rule out that you redeemed and forgot.\n\nMedian outcome: 24-72 hours from contact to decision. Approval rate is moderate - lower than refund requests, higher than account-disable appeals. Apple\'s position is that the retailer is the primary responsible party.',
    },
    {
      h: 'Returning to the retailer',
      p: 'The fastest path in many cases. The retailer\'s POS system has the activation record. If the gift card was activated by the retailer\'s register and is now showing as redeemed by someone else, the retailer activated a tampered card.\n\nWalk into the store with:\n\n- The receipt.\n- The physical gift card.\n- A photo of the redemption attempt failure on your phone.\n\nAsk for the customer service desk, not the cashier. Customer service usually has authority to issue a refund for fraudulent gift cards under the retailer\'s loss prevention policy. Major US chains (Target, Walmart, Best Buy, Costco) have established procedures for this scenario. Smaller retailers may push back, citing "no refund on gift cards" - that policy applies to legitimate card sales, not tampered ones, and in many US states retailers are legally on the hook for tampered cards.\n\nIf the retailer refuses:\n\n1. Ask to speak to a manager. Reference your state\'s consumer protection laws or the equivalent in your country.\n2. File with the state attorney general\'s consumer protection office (US) or the equivalent regulator.\n3. File with the FTC at reportfraud.ftc.gov (US). The FTC tracks this fraud pattern.\n4. Dispute the charge with your card-issuing bank as "merchandise not received" - the gift card had no usable value when delivered.\n\nBank chargebacks work for this case because the dispute is against the retailer, not Apple. Your Apple ID is unaffected.',
    },
    {
      h: 'Reporting to authorities and prevention',
      p: 'Even if your specific case does not recover the money, reporting helps stop the next victim. The fraud pattern is well-documented and law enforcement does prosecute when they have enough cases pinned to a single perpetrator.\n\nWhere to report:\n\n- FTC: reportfraud.ftc.gov. Free, online, 5 minutes. The FTC compiles patterns across reports.\n- Local police: file a report with the city or county police where the purchase happened. The retailer may need the police report to process their internal loss-prevention claim.\n- State attorney general\'s consumer protection office.\n- The retailer\'s own fraud hotline (Target, Walmart, Best Buy all have dedicated lines).\n- Apple at apple.com/legal/intellectual-property/trademark/claimsofcopyright.html (if scammers are using Apple branding to promote the scam).\n\nFuture prevention:\n\n- Digital gift cards eliminate the rack-skimming risk. Apple sells them at apple.com/giftcards.\n- If buying physical, take a card from the back of the rack, not the front.\n- Check for tampering: the foil scratch-off layer should be intact and uniform. Any holes, glue residue, or replacement stickers are red flags.\n- Save the receipt and the card itself until you have successfully redeemed.\n- Redeem soon after purchase, not weeks later.\n- Buy from trusted retailers with cooperative refund policies.',
    },
  ],
  faqItems: [
    {
      q: 'How long do I have to report a tampered gift card?',
      a: 'Sooner is better. Major retailers process gift-card fraud refunds within 30-60 days of purchase; some take longer with sufficient evidence. Apple\'s gift-card team also moves faster on recent purchases (the database state is fresh). Older cases (6+ months) get harder.',
    },
    {
      q: 'Can I just buy a new card if the first one was tampered?',
      a: 'You can, but buy from a different rack or a different store. The same rack often has multiple tampered cards if scammers were active there. Inspect the new card carefully before purchase.',
    },
    {
      q: 'Will the scammer be caught?',
      a: 'Sometimes. Apple maintains internal records of redemption IPs and device fingerprints; combined with law enforcement, multi-victim patterns sometimes lead to arrests. Your individual case being prosecuted is unlikely, but reporting feeds the broader investigation.',
    },
    {
      q: 'Does my homeowner\'s or renter\'s insurance cover stolen gift cards?',
      a: 'Most do not. Gift cards fall under "money equivalents" which are often excluded or capped at low amounts. Check the policy; some premium plans cover it.',
    },
    {
      q: 'Is buying gift cards on Amazon, eBay, or third-party sellers safer?',
      a: 'Amazon: yes, when sold and shipped by Amazon directly. eBay and other resellers: no - much higher fraud rate. Apple specifically warns against buying gift cards from any unofficial reseller. Stick to Apple, major retailers, or Amazon-direct.',
    },
  ],
};
---

<PageLayout
  title={`${copy.title} - Zero Balance`}
  description={copy.description}
  {lang}
  {path}
  schema={[
    articleSchema({ title: copy.title, description: copy.description, slug, lang, datePublished: published }),
    faqSchema(copy.faqItems),
    breadcrumbSchema([
      { name: 'Home', url: `${DOMAIN}/${lang}/` },
      { name: 'Blog', url: `${DOMAIN}/${lang}/blog/` },
      { name: copy.title, url: `${DOMAIN}${path}` },
    ]),
  ]}
  ogType="article"
  publishedTime={published}
  modifiedTime={published}
  keywords={[
    'apple gift card already redeemed',
    'apple gift card not working',
    'gift card code invalid apple',
    'apple gift card tampered',
    'apple gift card scam',
    ...t.keywords.leftoverGiftCard,
  ]}
>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />

  <Section>
    <Container>
      <Reveal class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--brand-soft)]/40 p-6 md:p-8">
          <p class="text-sm font-semibold tracking-wide text-[var(--brand-strong)] uppercase">TL;DR</p>
          <p class="mt-3 text-lg leading-relaxed text-[var(--fg)]">{copy.tldr}</p>
          <div class="mt-6 flex">
            <AppStoreButton label={t.cta.appStore} ct="blog-already-redeemed-tldr" />
          </div>
        </div>
      </Reveal>

      <div class="mx-auto mt-10 max-w-3xl prose-zb">
        {
          copy.sections.map((s, i) => (
            <Reveal delay={i * 40}>
              <h2>{s.h}</h2>
              {s.p.split('\n\n').map((para) => (
                <p>{para}</p>
              ))}
              {i === 4 && (
                <div class="not-prose my-6 flex">
                  <AppStoreButton label={t.cta.appStore} ct="blog-already-redeemed-mid" />
                </div>
              )}
            </Reveal>
          ))
        }

        <Reveal>
          <h2>Related questions</h2>
        </Reveal>
        <Reveal>
          <FAQ items={copy.faqItems} />
        </Reveal>
      </div>
    </Container>
  </Section>

  <FinalCta {lang} />
</PageLayout>
